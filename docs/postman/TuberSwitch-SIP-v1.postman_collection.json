{
  "info": {
    "_postman_id": "01fe5731-1c0e-4a75-9c6d-cff542167119",
    "name": "TuberSwitch SIP v1",
    "description": "Local TuberSwitch SIP v1.1 collection for LivePanel-compatible discovery, status, and profile activation. Start TuberSwitch first, then set baseUrl to the active SIP port, usually http://127.0.0.1:47040.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Discovery",
      "item": [
        {
          "name": "Get App Identity",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/app",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "app"
              ]
            },
            "description": "Returns TuberSwitch identity, app version, runtime mode, and SIP protocol version."
          },
          "response": []
        },
        {
          "name": "Get Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "health"
              ]
            },
            "description": "Returns SIP readiness and lightweight application health."
          },
          "response": []
        },
        {
          "name": "Get Capabilities",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/capabilities",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "capabilities"
              ]
            },
            "description": "Returns supported SIP feature flags."
          },
          "response": []
        },
        {
          "name": "Get Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "status"
              ]
            },
            "description": "Returns lightweight runtime status, active TuberSwitch profile, and additive LivePanel drawer details for OBS, redeems, and app detection."
          },
          "response": [
            {
              "name": "Ready with runtime details",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/status",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "status"
                  ]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "cookie": [],
              "body": "{\n  \"state\": \"ready\",\n  \"message\": \"Profile active\",\n  \"healthy\": true,\n  \"activeProfile\": \"Default\",\n  \"activeProfileId\": \"default\",\n  \"activeMode\": \"png\",\n  \"obsSummary\": \"Connected: Gaming / PNG\",\n  \"obsConnected\": true,\n  \"activeScene\": \"Gaming\",\n  \"activeSource\": \"PNG\",\n  \"redeemsEnabled\": true,\n  \"redeemCount\": 2,\n  \"manageableRedeemCount\": 1,\n  \"unmanageableRedeemCount\": 1,\n  \"appDetectionStatus\": \"PNG app detected\",\n  \"appDetectionEnabled\": true,\n  \"currentModeLabel\": \"PNGTuber Mode\",\n  \"activeProfileLastUsed\": \"2026-06-10T12:00:00Z\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Profiles",
      "item": [
        {
          "name": "List Profiles",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/profiles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "profiles"
              ]
            },
            "description": "Returns available TuberSwitch profile names."
          },
          "response": []
        },
        {
          "name": "Get Current Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/profile/current",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "profile",
                "current"
              ]
            },
            "description": "Returns the active TuberSwitch profile id and name."
          },
          "response": []
        },
        {
          "name": "Activate Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"profile\": \"{{profileName}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "profile"
              ]
            },
            "description": "Activates an existing TuberSwitch profile by name. The name match is case-insensitive."
          },
          "response": []
        },
        {
          "name": "Activate Missing Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"profile\": \"Missing Profile\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "profile"
              ]
            },
            "description": "Expected to return 404 with { \"success\": false, \"error\": \"ProfileNotFound\" }."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:47040",
      "type": "string"
    },
    {
      "key": "profileName",
      "value": "Default",
      "type": "string"
    }
  ]
}
